# ==========================================================
# Tanilytics Infrastructure - Environment Configuration
# ==========================================================

# ----------------------------------------------------------
# Credentials
# ----------------------------------------------------------
REDPANDA_SUPERUSER=superuser
REDPANDA_PASSWORD=secretpassword

# ----------------------------------------------------------
# Docker Images
# ----------------------------------------------------------
REDPANDA_IMAGE=docker.redpanda.com/redpandadata/redpanda:v25.3.10
CONSOLE_IMAGE=docker.redpanda.com/redpandadata/console:v3.6.0
REDIS_IMAGE=redis:8.2-bookworm
CLICKHOUSE_IMAGE=clickhouse/clickhouse-server:25.3

# ----------------------------------------------------------
# Broker Settings
# ----------------------------------------------------------
REDPANDA_MODE=dev-container
REDPANDA_SMP=1
REDPANDA_LOG_LEVEL=info

# ----------------------------------------------------------
# External Ports - Broker 0
# NOTE: Changing these requires updating both port mappings
# and the corresponding --kafka-addr / --pandaproxy-addr /
# --schema-registry-addr command args in docker-compose.yml
# ----------------------------------------------------------
REDPANDA_0_SCHEMA_PORT=18081
REDPANDA_0_PROXY_PORT=18082
REDPANDA_0_KAFKA_PORT=19092
REDPANDA_0_ADMIN_PORT=19644

# ----------------------------------------------------------
# External Ports - Broker 1
# ----------------------------------------------------------
REDPANDA_1_SCHEMA_PORT=28081
REDPANDA_1_PROXY_PORT=28082
REDPANDA_1_KAFKA_PORT=29092
REDPANDA_1_ADMIN_PORT=29644

# ----------------------------------------------------------
# External Ports - Broker 2
# ----------------------------------------------------------
REDPANDA_2_SCHEMA_PORT=38081
REDPANDA_2_PROXY_PORT=38082
REDPANDA_2_KAFKA_PORT=39092
REDPANDA_2_ADMIN_PORT=39644

# ----------------------------------------------------------
# Console Port
# ----------------------------------------------------------
CONSOLE_PORT=8080

# ----------------------------------------------------------
# Redis
# ----------------------------------------------------------
REDIS_PORT=6379

# ----------------------------------------------------------
# ClickHouse
# ----------------------------------------------------------
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_TCP_PORT=9000
CLICKHOUSE_DATABASE=default
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=change-me
CLICKHOUSE_DEFAULT_ACCESS_MANAGEMENT=1

# ----------------------------------------------------------
# Topic: raw-events
# ----------------------------------------------------------
RAW_EVENTS_TOPIC=raw-events
RAW_EVENTS_PARTITIONS=12
RAW_EVENTS_REPLICAS=1 # for local dev should be increased in prod
RAW_EVENTS_CLEANUP_POLICY=delete
RAW_EVENTS_RETENTION_MS=259200000 # 3 days
RAW_EVENTS_RETENTION_BYTES=-1
RAW_EVENTS_COMPRESSION=lz4

# ----------------------------------------------------------
# Topic: dlq (Dead Letter Queue)
# ----------------------------------------------------------
DLQ_TOPIC=dlq
DLQ_PARTITIONS=1
DLQ_REPLICAS=1 # for local dev should be increased in prod
DLQ_CLEANUP_POLICY=delete
DLQ_RETENTION_MS=604800000 # 7 days
DLQ_COMPRESSION=none

# ----------------------------------------------------------
# Console Authentication
# ----------------------------------------------------------
CONSOLE_JWT_SIGNING_KEY=CBuOnYpZTJCijXGxGNMn8vMfFVKNUOAT1vCsIUFvC1ZZm69W/JpT/mx1BAT2ya2EJSxBp3I9NFI7cs61bTZAsQ==

# ----------------------------------------------------------
# Shared Service Configuration (Ingestion + Processing)
# ----------------------------------------------------------
REDPANDA_BROKERS=redpanda-0:9092
REDPANDA_SASL_USER=superuser
REDPANDA_SASL_PASSWORD=secretpassword
REDPANDA_SASL_MECHANISM=SCRAM-SHA-256
REDIS_URL=redis://redis:6379
LOG_LEVEL=debug
OTEL_EXPORTER_OTLP_ENDPOINT=jaeger:4318

# ----------------------------------------------------------
# ClickHouse Migrations
# ----------------------------------------------------------
CLICKHOUSE_MIGRATIONS_URL=clickhouse://localhost:9000?database=default&username=default&password=change-me&x-migrations-table=schema_migrations&x-migrations-table-engine=MergeTree

# ----------------------------------------------------------
# Ingestion Service
# ----------------------------------------------------------
INGESTION_PORT=:3000
BLOOM_FILTER_CAPACITY=1000000
BLOOM_FILTER_ERROR_RATE=0.001

# ----------------------------------------------------------
# Processing Service
# ----------------------------------------------------------
PROCESSING_PORT=:3000
CONSUMER_GROUP=event-processor
CONSUMER_TOPIC=raw-events
CONSUMER_RESET_OFFSET=end
CONSUMER_FETCH_MIN_BYTES=65536
CONSUMER_FETCH_MAX_BYTES=52428800
CONSUMER_FETCH_MAX_WAIT=250ms
CONSUMER_FETCH_MAX_PARTITION_BYTES=4194304
CONSUMER_BLOCK_REBALANCE_ON_POLL=false
CONSUMER_MAX_CONCURRENT_FETCHES=2
CLICKHOUSE_ADDRS=clickhouse:9000
CLICKHOUSE_DIAL_TIMEOUT=5s
CLICKHOUSE_MAX_OPEN_CONNS=10
CLICKHOUSE_MAX_IDLE_CONNS=5
CLICKHOUSE_CONN_OPEN_STRATEGY=in_order
CH_BATCH_SIZE=10000
CH_BATCH_TIMEOUT=5s
ANONYMIZATION_SALT=change-me
